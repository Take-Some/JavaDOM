<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">[%d{HH:mm:ss.SSS}] %-5level [%c{1}] [%t]: %msg%n</Property>
        <Property name="CONSOLE_PATTERN">%style{[%d{HH:mm:ss.SSS}]}{black,bold} %highlight{%-5level}{FATAL=red blink, ERROR=red, WARN=yellow, INFO=green, DEBUG=cyan, TRACE=blue} [%style{%c{1}}{cyan}] [%t]: %msg%n</Property>
        <Property name="LOG_FILE">${sys:helix.logFile:-logs/helix.log}</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                disableAnsi="false"
                noConsoleNoAnsi="false"
                pattern="${CONSOLE_PATTERN}"/>
        </Console>

        <File name="File" fileName="${LOG_FILE}" append="false" createOnDemand="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </File>
    </Appenders>

    <Loggers>
        <Logger name="dev.takesome.helix" level="trace" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <Logger name="dev.takesome.helix.concurrent" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <Root level="warn">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>
</Configuration>
